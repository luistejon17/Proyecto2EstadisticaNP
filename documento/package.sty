% Contador único compartido, reseteado por sección
\newtheorem{thmcounter}{Thm}[section]

% Definición (verde)
\newtheoremstyle{definicionStyle}
{3pt}{3pt}{\normalfont}{}
{\color{verdee}\bfseries}{.}{ }{}
\theoremstyle{definicionStyle}
\newtheorem{definicion}[thmcounter]{Definici\'on}

% Proposición (azul claro)
\newtheoremstyle{proposicionStyle}
{3pt}{3pt}{\normalfont}{}
{\color{bluePropo}\bfseries}{.}{ }{}
\theoremstyle{proposicionStyle}
\newtheorem{proposicion}[thmcounter]{Proposici\'on}

% Corolario (azul medio)
\newtheoremstyle{corolarioStyle}
{3pt}{3pt}{\normalfont}{}
{\color{blueCoro}\bfseries}{.}{ }{}
\theoremstyle{corolarioStyle}
\newtheorem{corolario}[thmcounter]{Corolario}

% Teorema (azul oscuro) — `teorema` (ES) y `theorem` (EN, alias)
\newtheoremstyle{teoremaStyle}
{3pt}{3pt}{\normalfont}{}
{\color{blueThm}\bfseries}{.}{ }{}
\theoremstyle{teoremaStyle}
\newtheorem{teorema}[thmcounter]{Teorema}
\newtheorem{theorem}[thmcounter]{Teorema}

% Lema (azul-verdoso)
\newtheoremstyle{lemaStyle}
{3pt}{3pt}{\normalfont}{}
{\color{cadetblue}\bfseries}{.}{ }{}
\theoremstyle{lemaStyle}
\newtheorem{lema}[thmcounter]{Lema}
\newtheorem{lemma}[thmcounter]{Lema}

% Observación (amarillo/oro)
\newtheoremstyle{observacionStyle}
{3pt}{3pt}{\normalfont}{}
{\color{amaObs}\bfseries}{.}{ }{}
\theoremstyle{observacionStyle}
\newtheorem{observacion}[thmcounter]{Observaci\'on}

% Remark (magenta oscuro)
\newtheoremstyle{remarkStyle}
{3pt}{3pt}{\normalfont}{}
{\color{dunkelmagenta}\bfseries}{.}{ }{}
\theoremstyle{remarkStyle}
\newtheorem{remark}[thmcounter]{Remark}

% Hecho (frambuesa)
\newtheoremstyle{hechoStyle}
{3pt}{3pt}{\normalfont}{}
{\color{darkraspberry}\bfseries}{.}{ }{}
\theoremstyle{hechoStyle}
\newtheorem{hecho}[thmcounter]{Hecho}

% Datazo (granate brillante) — el favorito
\newtheoremstyle{datazoStyle}
{3pt}{3pt}{\normalfont}{}
{\color{brightmaroon}\bfseries}{.}{ }{}
\theoremstyle{datazoStyle}
\newtheorem{datazo}[thmcounter]{Datazo}

% Ejemplo (oliva)
\newtheoremstyle{ejemploStyle}
{3pt}{3pt}{\normalfont}{}
{\color{olive}\bfseries}{.}{ }{}
\theoremstyle{ejemploStyle}
