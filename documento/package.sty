% Estrategia (rojo cursiva, dos puntos)
\newtheoremstyle{estrategiaStyle}
{3pt}{3pt}{\normalfont}{}
{\color{red}\itshape}{:}{ }{}
\theoremstyle{estrategiaStyle}
